{
  "name": "osprey-fingerbot-control-panel",
  "version": "0.1.0",
  "description": "Control panel to switch E300 miners off/on via Tuya fingerbots, driven by ERCOT real-time price + grid curtailment.",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/server/index.ts",
    "start": "tsx src/server/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "web:dev": "npm --prefix web run dev",
    "web:build": "npm --prefix web run build"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/static": "^7.0.4",
    "fastify": "^4.28.1",
    "node-html-parser": "^6.1.13"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
