# ─── Tuya Cloud (Western America data center) ──────────────────────────────
# Lấy từ Tuya IoT Platform > Cloud > Project > Overview. ĐỪNG commit giá trị thật.
TUYA_CLIENT_ID=your_tuya_client_id
TUYA_CLIENT_SECRET=your_tuya_client_secret
TUYA_BASE=https://openapi.tuyaus.com

# device_id từng fingerbot — nên điền THẲNG vào config/switches.json.
# 2 biến dưới chỉ để map nhanh 2 con PoC (switches.json sw1 dùng env:DEVICE_A/B).
DEVICE_A=your_device_a_id
DEVICE_B=your_device_b_id

# ─── Chế độ điều khiển ─────────────────────────────────────────────────────
# dry-run (mặc định, KHÔNG bắn lệnh Tuya thật) | live (điều khiển fingerbot thật)
CONTROL_MODE=dry-run

# ─── Server ────────────────────────────────────────────────────────────────
PORT=8080

# ─── Nguồn giá ERCOT ───────────────────────────────────────────────────────
# mock          : giá giả lập (dev)
# ercot         : fetch HTML thuần — chạy tốt khi IP server không bị Incapsula chặn (datacenter US sạch). MẶC ĐỊNH NÊN DÙNG.
# ercot-browser : FALLBACK dùng Chromium (Playwright) tự qua Incapsula JS challenge.
#                 CHỈ chạy nếu image build với WITH_BROWSER=true (xem docker-compose.yml). Image nặng hơn nhiều.
PRICE_SOURCE=mock
# Settlement Point / Load Zone của datacenter — tạm dùng LZ_NORTH để test, CHỜ JAY XÁC NHẬN.
ERCOT_SETTLEMENT_POINT=LZ_NORTH
# Chỉ áp dụng khi PRICE_SOURCE=ercot-browser:
#   true  = Chromium headless (nhẹ, thường đủ khi IP server sạch)
#   false = Chromium headful dưới Xvfb (khó bị Incapsula phát hiện nhất) — đổi sang false rồi
#           `docker compose up -d` (KHÔNG cần --build) nếu headless bị chặn. Xem data/ercot-debug.png khi lỗi.
ERCOT_BROWSER_HEADLESS=true
# Chu kỳ poll giá (giây). ERCOT đổi mỗi 15 phút; poll dày hơn để bắt sớm.
PRICE_POLL_SECONDS=120

# ─── Ngưỡng quyết định ($/MWh) — CHỜ SẾP/JAY CHỐT ──────────────────────────
SWITCH_OFF_COST=100
SWITCH_ON_COST=60
# Số phút giá phải giữ ổn định quá ngưỡng trước khi hành động.
CONFIRM_MINUTES=2

# ─── Thời gian thực thi ────────────────────────────────────────────────────
# Delay giữa các switch khi tắt/bật tuần tự (ms).
DELAY_SWITCH_MS=2000
# Wake-prime: gửi mồi đánh thức rồi chờ (ms) trước khi bắn lệnh thật.
PRIME_WAIT_MS=6000
# Verify/retry.
CONFIRM_TIMEOUT_MS=30000
RESEND_MS=5000
POLL_MS=2500
# Keep-warm: tái khẳng định trạng thái mỗi N giây để giữ fingerbot "ấm". 0 = tắt.
KEEPWARM_SECONDS=0
